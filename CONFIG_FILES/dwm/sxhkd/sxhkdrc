# =============================================================================
#
#  Simple Arch - Fully Optimized sxhkdrc (Farook's Desktop Keybindings)
# =============================================================================

# 💻 TERMINALS & SHELLS
# Main Terminal emulator (Using Kitty as requested)
super + Return
    kitty --directory ~/

# Open Terminal with File Manager (Ranger via Alacritty)
super + shift + Return
    alacritty -e ranger ~/

# Open Modern Terminal File Manager (Yazi)
super + shift + f
    alacritty -e yazi ~/Downloads

# Open Terminal in Sudo mode (Using Kitty safely)
super + shift + t
    kitty -e sudo -i


# 🚀 APPLICATION LAUNCHERS (Rofi Setup)
# Open Application Finder (Using customized Rofi Arthur theme instead of xfce4)
super + slash
    rofi -show drun -theme arthur

# Main App Menu launcher
super + d
    rofi -show drun -theme arthur


# [เมนูสำรอง] เรียกใช้ Dmenu (เร็ว แรง เบาหวิว เอาไว้กู้ชีพยาม Rofi เอ๋อ)
super + p
    dmenu_run -fn 'JetBrainsMono Nerd Font:size=11' -nb '#2e3440' -nf '#d8dee9' -sb '#88c0d0' -sf '#2e3440'

# Show Theme Selector 
super + r
    rofi-theme-selector

# Power Session Menu (Shutdown, Reboot, Logout)
super + x
    rofi -show power-menu -modi power-menu:rofi-power-menu


# 🌐 WEB BROWSERS (Mapped with installed core browsers)
super + F1
    google-chrome --no-default-browser-check

super + F2
    firefox --no-default-browser-check

super + F3
    chromium --no-default-browser-check


# 🎨 MULTIMEDIA & UTILITIES
# Video/Media Player
super + F6
    vlc

# Music Player (Cmus run via Alacritty smoothly)
super + m
    alacritty -e sh -c "cmus; cmus-remote -C 'update-cache -f'"

# System Resource Monitor (Btop via Alacritty)
super + shift + h
    alacritty -e btop

# Audio Mixer GUI Controller
super + v
    pavucontrol

# Screenshot Utility (Instantly open capture and edit)
Print
    spectacle

# Graphical File Manager (Nautilus from your setup list)
super + t
    nautilus ~/

# Bluetooth Manager
super + shift + b
    blueman-manager


# 🔒 SYSTEM CONTROL & LOCK
# Lock Screen using blur-lock as requested by Farook
super + shift + l
    blurlock
    

# Toggle Picom (Compositor Shadows/Transparency)
ctrl + alt + o
    ~/.config/dwm/scripts/picom-toggle.sh

# Reset/Restart Keyboard Layout Script (Fixed keybinding to super+alt+k)
super + alt + k
    ~/.config/dwm/custom_script/set_kb.sh
